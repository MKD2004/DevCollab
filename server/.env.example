PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/devcollab?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed frontend origins for CORS (REST + Socket.io).
# Defaults to http://localhost:5173 (Vite dev server) if unset — set this to
# your deployed frontend URL(s) in production.
CLIENT_ORIGIN=http://localhost:5173
# Optional — enables the Socket.io Redis adapter for multi-instance scaling.
# Leave unset for single-process local dev (in-memory adapter is used instead).
# Managed providers (Upstash, Render Key Value, etc.) typically require TLS —
# use rediss:// (not redis://) or the connection will hang/reset.
REDIS_URL=rediss://default:<password>@<host>:<port>
# Self-hosted Piston code execution engine — run `docker compose up -d` at the
# repo root (see docker-compose.yml), then install language packages via its
# /api/v2/packages endpoint. Defaults to this local container if unset; the
# public emkc.org API went whitelist-only 2/15/2026 and can no longer be used
# without a registered key.
PISTON_URL=http://localhost:2000/api/v2
